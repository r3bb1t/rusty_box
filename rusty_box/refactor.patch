diff --git a/rusty_box/src/cpu/signal.rs b/rusty_box/src/cpu/signal.rs
new file mode 100644
index 0000000..71d5c14
--- /dev/null
+++ b/rusty_box/src/cpu/signal.rs
@@ -0,0 +1,134 @@
+//! CPU interrupt signal state shared between CPU, PIC, pc_system, and LAPIC.
+//!
+//! Replaces raw `*mut u32` pointers that PIC/pc_system/LAPIC used to write
+//! directly into CPU's `pending_event` and `async_event` fields. Single-threaded
+//! emulator: `Cell<u32>` provides zero-cost interior mutability without atomics.
+
+use core::cell::Cell;
+
+/// Shared CPU interrupt signal state.
+///
+/// Owned by Emulator via `Rc<CpuSignal>` and cloned into every component that
+/// needs to signal the CPU (PIC, pc_system, LAPIC). All access is single-threaded.
+///
+/// # Event bits (matching Bochs cpu.h)
+/// - Bit 0: `BX_EVENT_PENDING_INTR` — external interrupt from PIC
+/// - Bit 2: `BX_EVENT_PENDING_LAPIC_INTR` — LAPIC interrupt
+/// - Other bits defined by CPU event system
+///
+/// # `async_event`
+/// When non-zero, forces the CPU to break out of the inner trace loop and
+/// call `handle_async_event()`. Set to 1 by `raise_intr`/`set_hrq`, and
+/// also used for `BX_ASYNC_EVENT_STOP_TRACE` (bit 31).
+#[derive(Debug)]
+pub struct CpuSignal {
+    pending_event: Cell<u32>,
+    async_event: Cell<u32>,
+}
+
+impl CpuSignal {
+    pub fn new() -> Self {
+        Self {
+            pending_event: Cell::new(0),
+            async_event: Cell::new(0),
+        }
+    }
+
+    // ── pending_event accessors ──────────────────────────────────────────
+
+    #[inline]
+    pub fn pending_event(&self) -> u32 {
+        self.pending_event.get()
+    }
+
+    #[inline]
+    pub fn set_pending_event(&self, val: u32) {
+        self.pending_event.set(val);
+    }
+
+    /// `pending_event |= bits`
+    #[inline]
+    pub fn raise_pending(&self, bits: u32) {
+        self.pending_event.set(self.pending_event.get() | bits);
+    }
+
+    /// `pending_event &= !bits`
+    #[inline]
+    pub fn clear_pending(&self, bits: u32) {
+        self.pending_event.set(self.pending_event.get() & !bits);
+    }
+
+    // ── async_event accessors ────────────────────────────────────────────
+
+    #[inline]
+    pub fn async_event(&self) -> u32 {
+        self.async_event.get()
+    }
+
+    #[inline]
+    pub fn set_async_event(&self, val: u32) {
+        self.async_event.set(val);
+    }
+
+    /// `async_event |= bits`
+    #[inline]
+    pub fn raise_async(&self, bits: u32) {
+        self.async_event.set(self.async_event.get() | bits);
+    }
+
+    /// `async_event &= !bits` — clear specific bits from async_event.
+    #[inline]
+    pub fn clear_async(&self, bits: u32) {
+        self.async_event.set(self.async_event.get() & !bits);
+    }
+
+    // ── Combined operations (matching Bochs signal/clear patterns) ──────
+
+    /// BX_RAISE_INTR: signal external interrupt pending.
+    /// Sets `pending_event |= BX_EVENT_PENDING_INTR` and `async_event = 1`.
+    /// Used by PIC and pc_system.
+    #[inline]
+    pub fn raise_intr(&self) {
+        const BX_EVENT_PENDING_INTR: u32 = 1 << 0;
+        self.raise_pending(BX_EVENT_PENDING_INTR);
+        self.set_async_event(1);
+    }
+
+    /// BX_CLEAR_INTR: clear external interrupt pending signal.
+    /// Clears `pending_event &= !BX_EVENT_PENDING_INTR`.
+    #[inline]
+    pub fn clear_intr(&self) {
+        const BX_EVENT_PENDING_INTR: u32 = 1 << 0;
+        self.clear_pending(BX_EVENT_PENDING_INTR);
+    }
+
+    /// Signal a CPU event: `pending_event |= event`, and if not masked,
+    /// set `async_event = 1`.
+    ///
+    /// `event_mask` is passed from the CPU — it's CPU-local state, not shared.
+    #[inline]
+    pub fn signal_event(&self, event: u32, event_mask: u32) {
+        self.raise_pending(event);
+        if (event & event_mask) == 0 {
+            self.set_async_event(1);
+        }
+    }
+
+    /// Clear a CPU event: `pending_event &= !event`.
+    #[inline]
+    pub fn clear_event(&self, event: u32) {
+        self.clear_pending(event);
+    }
+
+    /// Force async_event = 1 (used by set_hrq and other wake sources).
+    #[inline]
+    pub fn force_async(&self) {
+        self.set_async_event(1);
+    }
+}
+
+impl Default for CpuSignal {
+    fn default() -> Self {
+        Self::new()
+    }
+}
